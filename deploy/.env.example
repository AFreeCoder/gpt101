# =============================================================================
# GPT101 生产环境配置
# =============================================================================
# 复制此文件为 .env 并修改必要的值
# =============================================================================

# --- 应用配置 ---
APP_URL=https://gpt101.org
APP_NAME=GPT101
APP_IMAGE=ghcr.io/afreecoder/gpt101:latest
APP_IMAGE_REPOSITORY=ghcr.io/afreecoder/gpt101
# 逗号分隔；新渠道域名解析到同一服务后，在这里加入即可启用外部升级页。
# 注：官方域名 upgrade.gpt101.org 与 upgpt.app 已内置于代码默认集合，无需在此重复添加。
UPGRADE_PAGE_HOSTS=upgrade.gpt101.org

# --- 数据库配置 ---
POSTGRES_USER=gpt101
POSTGRES_PASSWORD=
POSTGRES_DB=gpt101

# --- 认证密钥 ---
# 生成方式：openssl rand -base64 32
AUTH_SECRET=

# --- 分析追踪（可选）---
NEXT_PUBLIC_GOOGLE_ADS_CONVERSION_SEND_TO=
GOOGLE_ANALYTICS_ID=
GOOGLE_ADS_ID=
BAIDU_ANALYTICS_ID=

# --- 时区 ---
TZ=Asia/Shanghai

# --- GitHub Actions Secrets ---
# SILICON_HOST
# SILICON_SSH_PRIVATE_KEY
# GHCR_USERNAME
# GHCR_TOKEN
