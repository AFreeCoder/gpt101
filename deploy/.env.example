# =============================================================================
# GPT101 生产环境配置
# =============================================================================
# 复制此文件为 .env 并修改必要的值
# =============================================================================

# --- 应用配置 ---
APP_URL=https://gpt101.org
APP_NAME=GPT101

# --- 数据库配置 ---
POSTGRES_USER=gpt101
POSTGRES_PASSWORD=
POSTGRES_DB=gpt101

# --- 认证密钥 ---
# 生成方式：openssl rand -base64 32
AUTH_SECRET=

# --- 分析追踪（可选）---
GOOGLE_ANALYTICS_ID=
GOOGLE_ADS_ID=
BAIDU_ANALYTICS_ID=

# --- 时区 ---
TZ=Asia/Shanghai
